# Supabase – use your existing project URL and key from:
# https://supabase.com/dashboard/project/_/settings/api
#
# Project URL: Settings → API → Project URL
# anon public key: Settings → API → Project API keys → anon public

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: table to show on the list page (default: bug_reports)
# NEXT_PUBLIC_SUPABASE_TABLE=bug_reports
# Optional: table of captions to rate (default: captions)
# NEXT_PUBLIC_CAPTIONS_TABLE=captions
# Optional: Supabase Storage bucket for caption images (default: images)
# NEXT_PUBLIC_STORAGE_BUCKET=images
# Optional: custom base URL for caption images (e.g. https://images.example.com)
# When set, image paths are built as BASE_URL/path instead of SUPABASE_URL/storage/...
# NEXT_PUBLIC_IMAGE_BASE_URL=https://images.almostcrackd.ai

# Optional: caption pipeline API (default: https://api.almostcrackd.ai). Uses Supabase JWT as Bearer token.
# NEXT_PUBLIC_PIPELINE_API_URL=https://api.almostcrackd.ai

# Optional: if your project uses the new publishable key instead of anon
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
#
# Auth: In Supabase Dashboard → Auth → URL Configuration, set Redirect URL to:
#   https://your-domain.vercel.app/auth/callback  (and http://localhost:3000/auth/callback for dev)
